server {
    listen 80;
    listen [::]:80;
    server_name renpia.com www.renpia.com admin.renpia.com api.renpia.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name renpia.com www.renpia.com;

    ssl_certificate /etc/letsencrypt/live/renpia.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/renpia.com/privkey.pem;

    root /var/www/renpia/frontend/public;
    index index.html;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript application/xml+rss image/svg+xml;
    client_max_body_size 2m;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~ /\.(env|git) {
        deny all;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name admin.renpia.com;

    ssl_certificate /etc/letsencrypt/live/renpia.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/renpia.com/privkey.pem;

    root /var/www/renpia/frontend/admin;
    index index.html;

    gzip on;
    client_max_body_size 2m;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~ /\.(env|git) {
        deny all;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.renpia.com;

    ssl_certificate /etc/letsencrypt/live/renpia.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/renpia.com/privkey.pem;

    gzip on;
    client_max_body_size 2m;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    location ~ /\.(env|git) {
        deny all;
    }
}
